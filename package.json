{
  "name": "breakdown-ui",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "npx expo export --platform web",
    "test": "jest --watchAll=false",
    "test:unit": "JEST_ENV=unit jest --watchAll=false",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@expo-google-fonts/ibm-plex-mono": "^0.2.3",
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo-google-fonts/space-grotesk": "^0.2.3",
    "@expo/metro-runtime": "~55.0.11",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "^5.0.0",
    "axios": "^1.7.0",
    "axios-auth-refresh": "^3.3.0",
    "expo": "~55.0.0",
    "expo-constants": "~55.0.16",
    "expo-font": "~55.0.8",
    "expo-linking": "~55.0.15",
    "expo-router": "~55.0.16",
    "expo-secure-store": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-unistyles": "^3.0.0",
    "react-native-web": "^0.21.0",
    "react-test-renderer": "19.2.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@expo/metro-config": "~55.0.9",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.0.0",
    "@types/react": "~19.2.10",
    "@types/react-native": "~0.73.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "~55.0.8",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.0",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "moduleNameMapper": {
      "^@/types/(.*)$": "<rootDir>/types/$1",
      "^@/api/(.*)$": "<rootDir>/api/$1",
      "^@/stores/(.*)$": "<rootDir>/stores/$1",
      "^@/queries/(.*)$": "<rootDir>/queries/$1",
      "^@/theme/(.*)$": "<rootDir>/theme/$1",
      "^@/(.*)$": "<rootDir>/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|react-native-unistyles|zustand|@tanstack)"
    ]
  }
}
